---
extends: default

ignore: |
  taskfiles/**
  .taskotter/**
  node_modules/**
  **/node_modules/**
  # Wails-generated build scaffolding (Taskfiles + platform bundles), like taskfiles/**.
  cmd/activity-tracker/build/**
  # Stray pre-merge copy of the UI project (now lives under cmd/activity-tracker).
  activity-tracker/**

rules:
  comments:
    min-spaces-from-content: 1

  comments-indentation: false

  braces:
    min-spaces-inside: 0
    max-spaces-inside: 1

  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true

  line-length:
    max: 140
    level: warning

  truthy:
    allowed-values: ["true", "false", "on", "off", "yes", "no"]
